{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "website",
  "compatibility_date": "2026-04-12",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "analytics_engine_datasets": [
    {
      "binding": "CLICKS",
      "dataset": "button_clicks"
    }
  ]
}
